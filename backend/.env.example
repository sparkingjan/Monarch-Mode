APP_NAME=Solo Leveling API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://localhost:3000
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIRESTORE_COLLECTION_USERS=users
ADMIN_VISIBLE_EMAILS=ishraqrather19@gmail.com
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_CURRENCY=INR
PREMIUM_MEMBERSHIP_PRICE_INR=99
PREMIUM_MEMBERSHIP_VALIDITY_DAYS=30
PREMIUM_MEMBERSHIP_PLAN_NAME=Monarch Mode Premium
NAME_CHANGE_PRICE_INR=100
# AI provider config (recommended)
AI_PROVIDER=gemini
AI_API_KEY=your_ai_api_key_here
AI_MODEL=gemini-2.5-flash
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Backward compatibility (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
IMAGE_STORE_DIR=data/images
IMAGE_STORE_DB_PATH=data/images.sqlite3
IMAGE_STORE_MAX_BYTES=8388608
IMAGE_STORE_GALLERY_LIMIT=9
